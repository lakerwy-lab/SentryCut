# Override these images when the deploy server cannot reach Docker Hub.
ARG NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
ARG NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine

FROM ${NODE_IMAGE} AS build

WORKDIR /app

# 先安装依赖再复制源码，提升 Docker 构建缓存命中率。
COPY ai-video-mixer-web/package*.json ./
RUN npm ci

COPY ai-video-mixer-web ./
RUN npm run build

FROM ${NGINX_IMAGE}

# Nginx 同时承载 SPA 静态文件和后端反向代理。
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
